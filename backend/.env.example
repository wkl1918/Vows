# =========================
# Backend Runtime Settings
# =========================

# HuggingFace token (for diarization / model downloads)
HF_TOKEN=hf_xxx

# LLM translation
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
LLM_TRANSLATE_BATCH_SIZE=30
LLM_TEMPERATURE=0.15

# IndexTTS local repo path (code repo, not model weights in this project)
INDEXTTS_DIR=/path/to/index-tts-main

# Optional proxy settings (uncomment only if needed)
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
